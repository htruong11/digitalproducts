{
  "name": "digitalproducts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config site/vite.config.ts",
    "build": "npm run typecheck && vite build --config site/vite.config.ts",
    "preview": "vite preview --config site/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "product:build": "tsx scripts/product-build/build-product.ts",
    "product:pdf": "tsx scripts/product-build/build-product.ts --pdf",
    "python:lint": "uv run ruff check .",
    "python:format:check": "uv run ruff format --check .",
    "python:typecheck": "uv run ty check",
    "python:test": "uv run pytest",
    "test": "vitest run",
    "quality": "npm run typecheck && npm run lint && npm run format:check && npm run python:lint && npm run python:format:check && npm run python:typecheck && npm run python:test && npm test && npm run product:build && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
